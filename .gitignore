# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template carries no secrets, and the README/SetupNotice tell you
# to copy it. Without this it never reaches the repo.
!.env.local.example

# vercel
.vercel

# cloudflare / opennext build output
/.open-next/
/.wrangler/
.dev.vars
.dev.vars.*

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only secret material handed over out of band (service-account keys,
# MCC ids, connection notes). MUST NEVER be committed.
/prompts/
*.key.json
GOOGLE_ADS_SA_KEY_JSON*.txt
