# Supabase — Project Settings → API
# Same Supabase project as the admin (dropscale-da); the portal uses its own
# tables (clients, ad_accounts, …) behind their own RLS.
# Copy this file to .env.local and fill in your project's keys.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Public base URL of THIS portal deployment. Used to build the links embedded
# in Supabase password-reset emails.
#
# Set it explicitly. Without it the app falls back to the request origin, and
# if that URL is not in Supabase → Authentication → URL Configuration →
# Redirect URLs, Supabase silently ignores it and uses the project's Site URL
# instead — which is how reset emails end up pointing at another domain.
# Port 3001 so it can run alongside the admin (3000) in local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
