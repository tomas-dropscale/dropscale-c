# Supabase — Project Settings → API
# Same Supabase project as the admin (dropscale-da); the portal uses its own
# tables (clients, ad_accounts, …) behind their own RLS.
# Copy this file to .env.local and fill in your project's keys.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Public base URL of THIS portal deployment. Used to build the links embedded
# in Supabase password-reset emails.
#
# Set it explicitly. Without it the app falls back to the request origin, and
# if that URL is not in Supabase → Authentication → URL Configuration →
# Redirect URLs, Supabase silently ignores it and uses the project's Site URL
# instead — which is how reset emails end up pointing at another domain.
# Port 3001 so it can run alongside the admin (3000) in local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Google Ads API (server-only — NOT NEXT_PUBLIC; set as Worker secrets in prod)
#
# Connection model: per-client OAuth. Each client clicks "Connect Google Ads"
# in the portal and authorises their own account; the portal stores their
# refresh token per ad_account, encrypted. So these are only the agency's
# shared OAuth *app* credentials + the developer token + the encryption key —
# there is NO agency refresh token here.
#
# When these are unset, the portal shows seeded demo data. Once they are set
# and a client has connected an account (with a Customer ID), that account
# shows live data.
#
# How to obtain each — walkthrough in scripts/google-ads-setup.md:
#   DEVELOPER_TOKEN   Google Ads → Tools → API Center.
#   CLIENT_ID/SECRET  Google Cloud Console → Credentials → OAuth 2.0 client
#                     (Web application). Add BOTH redirect URIs:
#                       https://dropscale.app/api/google-ads/callback
#                       http://localhost:3001/api/google-ads/callback
#   TOKEN_ENC_KEY     32 random bytes, base64. Generate with:
#                       node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_TOKEN_ENC_KEY=
# Optional — only when reading through a manager account (digits; dashes stripped).
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Optional — defaults to the current API version in code. Bump when one sunsets.
# GOOGLE_ADS_API_VERSION=v21
